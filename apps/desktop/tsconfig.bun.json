{
	"extends": "@qa-agent/typescript-config/base.json",
	"compilerOptions": {
		"lib": ["ES2022"],
		"types": ["bun"],
		"noEmit": true,
		"skipLibCheck": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noImplicitReturns": false
	},
	"include": ["src/bun", "src/shared", "electrobun.config.ts"],
	"exclude": ["dist", "node_modules"]
}
